# Local Docker Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://vocab:vocab@localhost:5433/vocabulary

# Neon Postgres connection string (set in Vercel project settings for preview/prod,
# only needed here if you want to point local dev at Neon)
# DATABASE_URL=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Merriam-Webster Dictionary API keys (free, register at https://dictionaryapi.com).
# Learner's is tried first (definitions written for English learners); the
# Intermediate school dictionary is the next fallback. Both are optional — the
# lookup falls back to free sources when unset.
MW_LEARNERS_KEY=
MW_INTERMEDIATE_KEY=
